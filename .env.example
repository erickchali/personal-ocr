# Manual installs for checking: uv, docker, docker compose

# ============================================================
# LLM Provider API Keys
# ============================================================
OPENAI_API_KEY='{your-key}'
TAVILY_API_KEY='{your-key}'
ANTHROPIC_API_KEY='{your-key}'
GOOGLE_API_KEY='{your-key}'

LLM_PROVIDER=openai

# ============================================================
# LangSmith (tracing / observability)
# ============================================================
LANGSMITH_API_KEY='{your-key}'
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=learning-path

# ============================================================
# Docker services — Host ports
# Change these if the defaults conflict with other processes.
# ============================================================
POSTGRES_HOST_PORT=5432
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
METABASE_HOST_PORT=3000

# ============================================================
# Postgres
# ============================================================
POSTGRES_USER=financial_assistant
POSTGRES_PASSWORD=financial_assistant_pw
POSTGRES_DB=financial_assistant
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://financial_assistant:financial_assistant_pw@localhost:5432/financial_assistant

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
